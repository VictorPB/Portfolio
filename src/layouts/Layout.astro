---
import NavBar from '../components/NavBar.astro'
import Footer from '../components/Footer.astro'
import { ClientRouter } from 'astro:transitions'
import Gradient from '@components/Gradient.astro'

interface Props {
	title?: string
	description?: string
	lang?: string
}

const {
	title = 'Portfolio de Vipeba',
	description = 'Portfolio de Víctor Pérez Barranco: proyectos, experiencia y publicaciones.',
	lang = 'es'
} = Astro.props as Props
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="/icon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter fallback="none" />
	</head>
	<body
		class="flex w-full flex-col items-center justify-center bg-slate-100 px-4 text-black dark:bg-[#121212] dark:text-white md:px-16 lg:px-32"
	>
		<a
			href="#main-content"
			class="sr-only z-50 rounded-md bg-white px-4 py-2 text-black shadow-md focus:not-sr-only focus:absolute focus:left-4 focus:top-4"
		>
			Saltar al contenido principal
		</a>
		<Gradient />
		<NavBar />
		<main id="main-content" class="w-full">
			<slot />
		</main>
		<Footer />
		<Gradient />
	</body>
</html>
<style is:global>
	:root {
		color-scheme: dark light;
	}
	html {
		font-family: system-ui, sans-serif;
		scroll-behavior: smooth;
	}
</style>
