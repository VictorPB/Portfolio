---
import NavBar from '../components/NavBar.astro'
import Footer from '../components/Footer.astro'
import SEO from '../components/SEO.astro'
import { ClientRouter } from 'astro:transitions'
import Gradient from '@components/Gradient.astro'

interface Props {
	title?: string
	description?: string
	lang?: string
	image?: string
	type?: 'website' | 'article'
	noindex?: boolean
}

const {
	title = 'Portfolio de Vipeba',
	description = 'Portfolio de Víctor Pérez Barranco: proyectos, experiencia y publicaciones.',
	lang = 'es',
	image = '/portfolio-preview.webp',
	type = 'website',
	noindex = false
} = Astro.props as Props

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Víctor Pérez Barranco',
	url: 'https://vipeba.dev',
	sameAs: ['https://www.linkedin.com/in/victorperezbarranco/', 'https://github.com/VictorPB'],
	jobTitle: 'Desarrollador Full Stack',
	knowsAbout: ['Astro', 'TypeScript', 'Tailwind CSS', 'Figma', 'Three.js']
}
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" href="/icon.ico" />
		<SEO {title} {description} {image} {type} {noindex} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		<slot name="head" />
		<ClientRouter fallback="none" />
	</head>
	<body
		class="flex w-full flex-col items-center justify-center overflow-x-hidden bg-slate-100 text-black dark:bg-[#121212] dark:text-white"
	>
		<a
			href="#main-content"
			class="sr-only z-50 rounded-md bg-white px-4 py-2 text-black shadow-md focus:not-sr-only focus:absolute focus:left-4 focus:top-4"
		>
			Saltar al contenido principal
		</a>
		<Gradient />
		<NavBar />
		<main id="main-content" class="flex w-full flex-col items-center justify-center px-4 md:px-16 lg:px-32">
			<slot />
		</main>
		<Footer />
	</body>
</html>
<style is:global>
	:root {
		color-scheme: dark light;
	}
	html {
		font-family: system-ui, sans-serif;
		scroll-behavior: smooth;
	}
</style>
