---
// 1. Forzamos el renderizado estático para que funcione getStaticPaths
export const prerender = true

import Layout from '@layouts/Layout.astro'
import { getProjectById } from '@data/projects'
import TechBadge from '@components/TechBadge.astro'
import Button from '@components/Button.astro'
import PreviewIcon from '@public/icons/PreviewIcon.astro'
import GithubIcon from '@public/icons/CodeIcon.astro'
import DesignIcon from '@public/icons/DesignIcon.astro'

import { getCollection } from 'astro:content'

// 2. Definimos las rutas basadas en los archivos reales
export async function getStaticPaths() {
	const posts = await getCollection('posts')

	return posts.map((post) => ({
		params: { id: post.slug }, // El nombre de la carpeta/archivo MDX
		props: { post } // Pasamos el objeto post completo
	}))
}

// 3. Obtenemos los datos de las props y de tu archivo TS
const { id } = Astro.params
const { post } = Astro.props

// 4. Si el post no existe (por si alguien entra a una URL manual), redirigimos
if (!post) {
	return Astro.redirect('/404')
}

// 5. Renderizamos el contenido MDX y buscamos los metadatos en tu data/projects.ts
const { Content } = await post.render()
const MyProject = id ? getProjectById(id) : null
if (!MyProject) {
	return Astro.redirect('/404')
}

const pageDescription = MyProject.description.join(' ')

const blogPostingSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: MyProject.title,
	description: pageDescription,
	image: new URL(MyProject.coverImage, Astro.site).toString(),
	url: Astro.url.toString(),
	author: {
		'@type': 'Person',
		name: 'Víctor Pérez Barranco',
		url: 'https://vipeba.dev'
	}
}
---

<Layout
	title={`${MyProject.title} | Blog Vipeba`}
	description={pageDescription}
	image={MyProject.coverImage}
	type="article"
>
	<script
		is:inline
		type="application/ld+json"
		set:html={JSON.stringify(blogPostingSchema)}
		slot="head"
	/>
	<article class="mt-20 flex w-full flex-col items-center justify-center md:w-[50vw]">
		<header class="flex w-full flex-col place-content-around items-center gap-8 xl:flex-row">
			<aside class="flex flex-col gap-6">
				<section>
					<h1
						class="text-4xl font-bold text-gray-900 dark:text-gray-100"
						transition:name=`project ${MyProject?.proyectId} title`
					>
						{MyProject?.title}
					</h1>
				</section>
				<section>
					<h3 class="mb-1 text-xl font-bold">Tecnologías</h3>
					<ul class="mb-2 flex flex-row flex-wrap gap-x-2 gap-y-1">
						{
							MyProject.technologies.map((technology) => (
								<li>
									<TechBadge {...technology} />
								</li>
							))
						}
					</ul>
				</section>
				<section>
					<h3 class="mb-1 text-xl font-bold">Enlaces</h3>
					<ul class="flex gap-2">
						{
							MyProject.repo && (
								<Button href={MyProject.repo} target="_blank">
									<GithubIcon class="size-5" />
									Código
								</Button>
							)
						}
						{
							MyProject.link && (
								<Button href={MyProject.link} target="_blank">
									<PreviewIcon class="size-5" />
									Preview
								</Button>
							)
						}
						{
							MyProject.design && (
								<Button href={MyProject.design} target="_blank">
									<DesignIcon class="size-5" />
									Diseño
								</Button>
							)
						}
					</ul>
				</section>
			</aside>
			<img
				class="w-full rounded-xl xl:w-[450px]"
				src={MyProject.coverImage}
				alt={`Vista previa de ${MyProject.title}`}
				transition:name=`project ${MyProject.proyectId} image`
			/>
		</header>

		<hr class="mb-10 w-full border-gray-200 dark:border-gray-800" />

		<div class="prose prose-neutral w-full max-w-none dark:prose-invert">
			<Content />
		</div>
	</article>
</Layout>
