---
import ThemeToggle from '@components/ThemeToggle.astro'
import CopyMailButton from './CopyMailButton.astro'
---

<section class="fixed top-0 z-10 mx-auto mt-2 flex items-center justify-center md:w-full">
	<header
		class="flex w-[100vw] items-center justify-between gap-1 rounded-full text-xs font-medium text-gray-600 dark:text-gray-200 md:w-auto md:justify-evenly md:gap-10 md:text-sm"
	>
		<a href="/#top"><img src="/logo.webp" alt="Vipeba" class="mx-3 w-12" /></a>
		<nav class="relative flex items-center gap-2 py-4 md:justify-between md:gap-4">
			<a
				href="/#experience"
				aria-label="experience"
				class="text-gray-800 hover:text-fuchsia-500 dark:text-white hover:dark:text-fuchsia-500"
			>
				Experiencia
			</a>
			<a
				href="/#projects"
				aria-label="projects"
				class="text-gray-800 hover:text-fuchsia-500 dark:text-white hover:dark:text-fuchsia-500"
			>
				Proyectos
			</a>
			<a
				href="/#about"
				aria-label="about"
				class="text-gray-800 hover:text-fuchsia-500 dark:text-white hover:dark:text-fuchsia-500"
			>
				Sobre Mí
			</a>
			<a
				href="/blog"
				class="text-gray-800 hover:text-fuchsia-500 dark:text-white hover:dark:text-fuchsia-500"
			>
				Blog
			</a>
			<button
				transition:persist
				id="contact"
				type="button"
				aria-controls="contact-menu"
				aria-expanded="false"
				class="flex cursor-pointer border-none text-gray-800 transition hover:text-fuchsia-500 dark:text-white hover:dark:text-fuchsia-500"
			>
				Contacto
			</button>
			<div
				transition:persist
				id="contact-menu"
				class="scale-80 absolute right-0 top-12 hidden w-fit rounded-md border border-gray-100 bg-white/90 p-1 text-sm shadow-[0_3px_10px_rgb(0,0,0,0.2)] backdrop-blur-md dark:border-gray-500/20 dark:bg-[#2F2F2F]"
			>
				<ul class="flex items-center justify-center gap-1 max-w-xs overflow-hidden">
					<li
						class="contact-menu-option cursor-default rounded-sm px-2 py-1.5 hover:bg-neutral-400/40 dark:hover:bg-gray-500/50"
					>
						<a href="mailto:victorperezbarrancodev@gmail.com" class="truncate" title="victorperezbarrancodev@gmail.com">victorperezbarrancodev@gmail.com</a>
					</li>
					<li class="flex justify-between">
						<CopyMailButton />
					</li>
				</ul>
			</div>
		</nav>
		<ThemeToggle />
	</header>
</section>

<script is:inline>
	const setupContactMenu = () => {
		const contact = document.getElementById('contact')
		const contactMenu = document.getElementById('contact-menu')

		if (!contact || !contactMenu) return
		if (contact.dataset.bound === 'true') return
		contact.dataset.bound = 'true'

		contact.onclick = (event) => {
			event.stopPropagation()
			const isHidden = contactMenu.classList.contains('hidden')
			contactMenu.classList.toggle('hidden')
			contact.setAttribute('aria-expanded', isHidden ? 'true' : 'false')
		}

		if (document.body.dataset.contactMenuGlobalBound !== 'true') {
			document.body.dataset.contactMenuGlobalBound = 'true'
			document.addEventListener('click', (event) => {
				const currentContact = document.getElementById('contact')
				const currentContactMenu = document.getElementById('contact-menu')
				if (!currentContact || !currentContactMenu) return
				if (
					!currentContactMenu.contains(event.target) &&
					!currentContact.contains(event.target)
				) {
					currentContactMenu.classList.add('hidden')
					currentContact.setAttribute('aria-expanded', 'false')
				}
			})

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					const currentContact = document.getElementById('contact')
					const currentContactMenu = document.getElementById('contact-menu')
					if (!currentContact || !currentContactMenu) return
					currentContactMenu.classList.add('hidden')
					currentContact.setAttribute('aria-expanded', 'false')
				}
			})
		}
	}

	document.addEventListener('DOMContentLoaded', setupContactMenu)
	document.addEventListener('astro:after-swap', setupContactMenu)
</script>

<style>
	header {
		animation: header-shadow 1s linear both;
		animation-timeline: scroll();
		animation-range: 0 100px;
	}

	header {
		@apply bg-white/50 dark:bg-[#121212]/90;
	}

	@keyframes header-shadow {
		0% {
			background-color: rgb(255 255 255 / 0);
		}
		to {
			@apply shadow-lg ring-1 ring-white/10 backdrop-blur;
		}
	}

	#contact-menu.open {
		display: inline;
	}
</style>
