---
const { href, target } = Astro.props
const rel = target === '_blank' ? 'noopener noreferrer' : undefined
---

<a
	target={target}
	href={href}
	rel={rel}
	role="link"
	class="group inline-flex max-h-fit max-w-fit items-center justify-center gap-2 rounded-xl border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-800 transition hover:border-gray-900 hover:bg-gray-800 hover:text-white focus:outline-none focus-visible:outline-none focus-visible:ring focus-visible:ring-white focus-visible:ring-yellow-500/80 focus-visible:ring-offset-2 active:bg-black dark:border-gray-600 dark:bg-[#303030] dark:text-white dark:hover:border-gray-300 dark:hover:bg-gray-100 dark:hover:text-black md:text-lg"
>
	<slot />
</a>
