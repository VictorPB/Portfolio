---
import SunIcon from '@public/icons/Sun.astro'
import MoonIcon from '@public/icons/Moon.astro'
---

<button
	transition:persist
	id="theme-toggle-btn"
	aria-label="Alternar tema"
	class="relative mx-4 flex size-5 appearance-none border-none transition hover:scale-125"
>
	<SunIcon id="icon-light" class="absolute size-5 transition-all" />
	<MoonIcon id="icon-dark" class="absolute size-5 transition-all" />
</button>

<script is:inline>
	const matchMedia = window.matchMedia('(prefers-color-scheme: dark)')

	const isDark = () => {
		const stored = localStorage.getItem('theme')
		if (stored === 'dark') return true
		if (stored === 'light') return false
		return matchMedia.matches
	}

	const applyTheme = (dark) => {
		document.documentElement.classList[dark ? 'add' : 'remove']('dark')
		const iconLight = document.getElementById('icon-light')
		const iconDark = document.getElementById('icon-dark')
		if (iconLight) iconLight.style.scale = dark ? '1' : '0'
		if (iconDark) iconDark.style.scale = dark ? '0' : '1'
	}

	const toggleTheme = () => {
		const dark = !document.documentElement.classList.contains('dark')
		localStorage.setItem('theme', dark ? 'dark' : 'light')
		applyTheme(dark)
	}

	const setupBtn = () => {
		const btn = document.getElementById('theme-toggle-btn')
		if (btn) btn.onclick = toggleTheme
	}

	applyTheme(isDark())
	setupBtn()

	if (!window.__themeListenersAttached) {
		window.__themeListenersAttached = true

		matchMedia.addEventListener('change', () => {
			if (!localStorage.getItem('theme')) applyTheme(matchMedia.matches)
		})

		document.addEventListener('astro:after-swap', () => {
			applyTheme(isDark())
			setupBtn()
			window.scrollTo({ left: 0, top: 0, behavior: 'instant' })
		})
	}
</script>
