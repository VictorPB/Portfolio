---
import Button from '@components/Button.astro'
import LinkedIn from '@public/icons/LinkedIn.astro'
import GitHub from '@public/icons/Github.astro'
import CV from '@public/icons/CV.astro'
---

<header
	class="flex flex-col items-center justify-center gap-10 pt-36 text-center lg:h-lvh lg:flex-row lg:pt-0"
>
	<aside class="flex w-full flex-col justify-evenly gap-5 lg:w-[60%]">
		<h1
			class="mb-4 text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-4xl lg:text-5xl"
		>
			<strong
				class="mt-3 bg-gradient-to-r from-rose-400 via-fuchsia-500 to-indigo-500 bg-clip-text font-extrabold text-transparent"
				>Hola!</strong
			> Soy Víctor Pérez Barranco
		</h1>
		<p
			class="dark:text-grey-400 text-pretty text-lg font-light text-gray-600 dark:text-gray-100 md:text-xl lg:text-2xl"
		>
			<strong class="font-semibold">Desarrollador Full Stack</strong> especializado en frontend moderno.
			Centrado en crear <strong class="font-semibold">diseños y animaciones</strong> de alto nivel, con
			atención obsesiva a detalles que marcan la diferencia.
		</p>
		<nav>
			<ul class="flex justify-center gap-4 align-middle">
				<Button href="https://www.linkedin.com/in/victorperezbarranco/" target="_blank">
					<LinkedIn class="size-6" />
					LinkedIn
				</Button>
				<Button href="https://github.com/VictorPB" target="_blank">
					<GitHub class="size-6" />
					GitHub
				</Button>
				<Button href="/CV-ES.pdf" target="_blank">
					<CV class="size-6" />
					CV
				</Button>
			</ul>
		</nav>
	</aside>
	<picture
		class="h-auto w-full max-w-80 overflow-hidden rounded-xl drop-shadow-2xl lg:relative lg:left-[50px] lg:rotate-6 lg:transform"
	>
		<img src="/Vipeba.webp" alt="Vipeba Photo" class="-rotate-6 scale-[115%]" />
	</picture>
</header>
