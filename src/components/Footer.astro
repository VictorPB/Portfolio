---
const year = new Date().getFullYear()
---

<footer
	class="mt-32 flex h-[70vh] w-screen flex-col justify-between bg-slate-100 px-8 py-14 text-neutral-950 dark:bg-[#111111] dark:text-white md:-mx-16 md:px-16 lg:-mx-32 lg:px-24"
>
	<!-- Top: Phrase + Nav -->
	<div class="flex flex-col gap-12 lg:grid lg:grid-cols-2 lg:grid-rows-1 lg:items-start">
		<!-- Big phrase -->
		<h2
			class="max-w-3xl text-5xl font-semibold uppercase leading-tight tracking-tight text-neutral-900 dark:text-neutral-100 md:text-6xl lg:col-span-1 lg:text-7xl xl:text-8xl"
		>
			¿Hablamos y creamos algo increíble?
		</h2>

		<!-- Nav columns -->
		<div class="flex shrink-0 gap-16 pt-2 lg:col-span-1 lg:ml-12 lg:gap-32">
			<!-- Sitemap -->
			<div class="flex flex-col gap-4">
				<span
					class="lg:text-md text-xs font-semibold uppercase tracking-widest text-neutral-400 dark:text-neutral-500"
					>Apartados</span
				>
				<ul class="flex flex-col gap-3">
					<li>
						<a
							href="/"
							class="group flex items-center gap-1 text-sm font-medium uppercase tracking-wide text-neutral-800 transition hover:text-fuchsia-500 dark:text-neutral-300 dark:hover:text-fuchsia-400 lg:text-lg"
						>
							Inicio <span
								class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
								>↗</span
							>
						</a>
					</li>
					<li>
						<a
							href="/#experience"
							class="group flex items-center gap-1 text-sm font-medium uppercase tracking-wide text-neutral-800 transition hover:text-fuchsia-500 dark:text-neutral-300 dark:hover:text-fuchsia-400 lg:text-lg"
						>
							Experiencia <span
								class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
								>↗</span
							>
						</a>
					</li>
					<li>
						<a
							href="/#projects"
							class="group flex items-center gap-1 text-sm font-medium uppercase tracking-wide text-neutral-800 transition hover:text-fuchsia-500 dark:text-neutral-300 dark:hover:text-fuchsia-400 lg:text-lg"
						>
							Proyectos <span
								class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
								>↗</span
							>
						</a>
					</li>
					<li>
						<a
							href="/#about"
							class="group flex items-center gap-1 text-sm font-medium uppercase tracking-wide text-neutral-800 transition hover:text-fuchsia-500 dark:text-neutral-300 dark:hover:text-fuchsia-400 lg:text-lg"
						>
							Sobre Mí <span
								class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
								>↗</span
							>
						</a>
					</li>
					<li>
						<a
							href="/blog"
							class="group flex items-center gap-1 text-sm font-medium uppercase tracking-wide text-neutral-800 transition hover:text-fuchsia-500 dark:text-neutral-300 dark:hover:text-fuchsia-400 lg:text-lg"
						>
							Blog <span
								class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
								>↗</span
							>
						</a>
					</li>
				</ul>
			</div>

			<!-- Connect -->
			<div class="flex flex-col gap-4">
				<span
					class="lg:text-md text-xs font-semibold uppercase tracking-widest text-neutral-400 dark:text-neutral-500"
					>Contacto</span
				>
				<ul class="flex flex-col gap-3">
					<li>
						<a
							href="https://www.linkedin.com/in/victorperezbarranco/"
							target="_blank"
							rel="noopener noreferrer"
							class="group flex items-center gap-1 text-sm font-medium uppercase tracking-wide text-neutral-800 transition hover:text-fuchsia-500 dark:text-neutral-300 dark:hover:text-fuchsia-400 lg:text-lg"
						>
							LinkedIn <span
								class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
								>↗</span
							>
						</a>
					</li>
					<li>
						<a
							href="https://github.com/VictorPB"
							target="_blank"
							rel="noopener noreferrer"
							class="group flex items-center gap-1 text-sm font-medium uppercase tracking-wide text-neutral-800 transition hover:text-fuchsia-500 dark:text-neutral-300 dark:hover:text-fuchsia-400 lg:text-lg"
						>
							GitHub <span
								class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
								>↗</span
							>
						</a>
					</li>
					<li>
						<a
							href="mailto:victorperezbarrancodev@gmail.com"
							class="group flex items-center gap-1 text-sm font-medium uppercase tracking-wide text-neutral-800 transition hover:text-fuchsia-500 dark:text-neutral-300 dark:hover:text-fuchsia-400 lg:text-lg"
						>
							Email <span
								class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
								>↗</span
							>
						</a>
					</li>
					<li>
						<a
							href="/CV-ES.pdf"
							class="group flex items-center gap-1 text-sm font-medium uppercase tracking-wide text-neutral-800 transition hover:text-fuchsia-500 dark:text-neutral-300 dark:hover:text-fuchsia-400 lg:text-lg"
						>
							CV <span
								class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
								>↗</span
							>
						</a>
					</li>
				</ul>
			</div>
		</div>
	</div>

	<!-- Bottom: Copyright + Signature -->
	<div
		class="mb-8 mt-16 flex flex-col items-start justify-between gap-6 border-t border-neutral-300 pt-8 dark:border-neutral-800 md:flex-row md:items-end"
	>
		<p class="text-xs text-neutral-500 dark:text-neutral-500 md:text-base">
			© {year} Vipeba. Casi todos los derechos reservados.
		</p>
		<img src="/signature.webp" alt="Firma Vipeba" class="w-48 opacity-80 dark:hidden md:w-64" />
		<img
			src="/signature-dark.webp"
			alt="Firma Vipeba"
			class="hidden w-48 opacity-80 dark:inline-flex md:w-64"
		/>
	</div>
</footer>
